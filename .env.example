# EV211 내부망 필드 서버 환경변수 예시 — 실제 값은 .env에 두고 커밋 금지
# LiveKit API 자격증명 (아래 LIVEKIT_KEYS 와 반드시 일치)
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=change-me-to-32-plus-random-chars

# LiveKit 컨테이너에 주입하는 keys 맵 (형식: "키: 시크릿").
# livekit.yaml 에는 키를 두지 않고 이 환경변수로만 주입한다.
# 값에 공백이 있으므로 따옴표로 감싼다(스크립트의 `. ./.env` 소싱 오류 방지, compose 는 따옴표 제거).
LIVEKIT_KEYS="devkey: change-me-to-32-plus-random-chars"

# 클라이언트에 광고할 서버 IP(ICE node-ip).
# - 로컬 개발: 127.0.0.1
# - 현장 배포: 반드시 서버 LAN IP 로 교체(예: 192.168.0.50). scripts/detect-ip.sh 로 감지.
# 미설정 시 docker-compose 가 127.0.0.1 로 폴백한다(로컬 개발 전용, LAN 단말 ICE 실패).
FIELD_NODE_IP=127.0.0.1

# 송신 콘솔 비밀번호 (웹/앱 /speak 접속 시 사용, .env 미설정이면 기동 실패 정책 대상 — Phase 1)
FIELD_SEND_PASSWORD=change-me

# 어드민 콘솔 비밀번호 (룸 세대 관리·강제 종료 등 운영 기능 접근용, Phase 1)
FIELD_ADMIN_PASSWORD=change-me

# RTC 미디어 UDP 범위(published 포트 = LiveKit 후보 할당 범위, 항상 일치해야 함).
# macOS 기본 42000-47000: ephemeral(49152~) 충돌 회피. Linux host-mode 는 50000/60000 로 확대 가능.
FIELD_UDP_START=42000
FIELD_UDP_END=47000

# 최대 채널 수 (트랙 ch-01 ~ ch-NN)
MAX_CHANNELS=15

# LiveKit 외부 접속 URL (수신/송신 페이지 토큰 발급 대상)
LIVEKIT_WS_URL=ws://localhost:7880

# field-api 가 토큰 응답의 url 필드로 반환하는 LiveKit signaling base URL(모바일 앱용).
# 모바일 앱 기본: 평문 ws://<서버IP>:7880 직결(#3). LiveKit SDK 는 자체서명 wss 의
# TOFU 예외를 공유하지 않으므로 CA 미설치 단말이 wss://IP:8443 에 연결하지 못한다.
# signaling 에는 비밀번호가 실리지 않고 단기 JWT 만 노출되며, 미디어는 WebRTC DTLS-SRTP
# 로 항상 암호화된다. 비밀번호가 실리는 인증 API 는 여전히 HTTPS(:8443) 전용이다.
# 웹 브라우저(https 페이지)는 speak-test.html 이 location 기반 wss 프록시(:8443)로
# 대체하므로(mixed content 회피) 이 값은 모바일 앱 토큰 응답용이다.
# 미설정 시 field-api 가 ws://<FIELD_NODE_IP>:7880 로 폴백한다.
# ⚠️ 아래 기본값은 루프백(127.0.0.1)이라 LAN 단말이 접속할 수 없다. 현장 배포 전
#    반드시 서버 LAN IP 로 교체하라. `./scripts/detect-ip.sh --write` 가 FIELD_NODE_IP 와
#    FIELD_WS_URL(ws://<IP>:7880)을 함께 실제 IP 로 갱신한다.
FIELD_WS_URL=ws://127.0.0.1:7880
# field-api SQLite 원장 경로(컨테이너 내부 /data 볼륨, 기본 /data/field.db).
FIELD_DB_PATH=/data/field.db

# MP3 녹음 저장 경로(컨테이너 내부 named volume).
FIELD_RECORDINGS_PATH=/data/recordings
